LORA_MODEL=devmentor-lora:latest

EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2
CHROMA_COLLECTION_NAME=devmentor_docs
CHROMA_PATH=chroma_db

DATA_DOCS_PATH=data/docs
DATA_ERRORS_PATH=data/errors
TOP_K=3
